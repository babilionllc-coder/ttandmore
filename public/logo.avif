<script>
(function () {
  // Pon aquí el ID REAL del input (o un selector CSS estable)
  const SELECTOR = '#direccion_google';

  function attachAutocomplete() {
    if (!window.google || !google.maps || !google.maps.places) return;

    const input = document.querySelector(SELECTOR);
    if (!input) return;

    // evita duplicar listeners si Elementor re-renderiza
    if (input.dataset.placesReady === '1') return;
    input.dataset.placesReady = '1';

    const ac = new google.maps.places.Autocomplete(input, {
      types: ['geocode'],
      componentRestrictions: { country: 'mx' }
    });

    ac.addListener('place_changed', function () {
      const place = ac.getPlace();
      // si quieres guardar algo en hidden fields, aquí es donde
      // console.log(place);
    });
  }

  // callback global para el script de Google
  window.initPlaces = function () {
    attachAutocomplete();

    // Reintenta un poco por si el popup/form aún no existe
    let tries = 0;
    const t = setInterval(() => {
      attachAutocomplete();
      tries++;
      if (tries > 20) clearInterval(t);
    }, 300);
  };

  // Cuando Elementor abre un popup, el input aparece después
  document.addEventListener('elementor/popup/show', function () {
    attachAutocomplete();
  });

  // Fallback general
  document.addEventListener('DOMContentLoaded', function () {
    attachAutocomplete();
  });
})();
</script>

</body>
