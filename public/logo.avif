					<div class="e-con-inner">
				<div class="elementor-element elementor-element-d1cb5be elementor-widget elementor-widget-html" data-id="d1cb5be" data-element_type="widget" data-e-type="widget" data-widget_type="html.default">
					<script>
document.addEventListener('DOMContentLoaded', function () {
  const origen = document.querySelector('[name="form_fields[zipcode]"]');
  const destino = document.querySelector('[name="form_fields[tabulador]"]');

  if (!origen || !destino) return;

  function setSelectValue(val) {
    // intenta por VALUE exacto
    let option = Array.from(destino.options).find(o => o.value == val);

    // si no existe por value, intenta por TEXTO visible
    if (!option) option = Array.from(destino.options).find(o => o.text.trim() == String(val).trim());

    if (option) {
      destino.value = option.value; // asigna el value correcto
      destino.dispatchEvent(new Event('change', { bubbles: true }));
    }
  }

  // copia inicial + al cambiar
  setSelectValue(origen.value);
  origen.addEventListener('input', () => setSelectValue(origen.value));
  origen.addEventListener('change', () => setSelectValue(origen.value));
});
</script>
